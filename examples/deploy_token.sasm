;; Deploy Token Script
;; Usage: shadowasm script examples/deploy_token.sasm --network local

;; @log Starting token deployment...

;; @fund deployer 1000000000000

;; @deploy MyToken
;; SRC-20 Token Contract
;; @fn transfer(uint64,address):bool
;; @fn balance_of(address):uint64
;; @event Transfer(address,address,uint64)

; Initialize total supply at slot 0
PUSH1 0xFF        ; supply = 255
PUSH1 0           ; slot 0
SSTORE
STOP

;; @call MyToken

;; @log Token deployment complete!
