# ShadowDAG miner configuration
# Copy this file to /etc/shadowdag/miner.env and edit the values below.
# The systemd miner service reads this file on start.

# REQUIRED: your miner payout address (testnet format starts with ST1...)
MINER_ADDRESS=ST1REPLACE_WITH_YOUR_TESTNET_ADDRESS

# Number of mining threads.
# Recommendation: start with 1 to avoid monotonic-timestamp rejections on fast hardware.
# Raise this only after confirming your timestamp monotonicity tolerance is wide enough.
MINER_THREADS=1
